# Copy this file to .env.local and edit values there.
# .env.local is gitignored.

# Base URL of the workflow API that handles RAG + LLM.
# Default (unset) = http://localhost:4002 → the mock-server in packages/mock-server.
# Point this at your real workflow webhook to go live.
# VITE_API_URL=https://your-workflow.example.com
